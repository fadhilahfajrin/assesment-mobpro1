    <string name="materi_penting">Pentingnya Air</string>
    <string name="materi_penting_desc">Air sangat penting untuk menjaga fungsi
        tubuh seperti metabolisme, suhu tubuh, dan kesehatan organ.
    </string>
    <string name="materi_kalori">Pentingnya Kalori</string>
    <string name="materi_kalori_desc">Kalori merupakan sumber energi bagi tubuh
        untuk melakukan aktivitas sehari-hari dan menjaga fungsi organ.
    </string>
    <string name="materi_faktor">Faktor Kebutuhan</string>
    <string name="materi_faktor_desc">
        • Berat badan
        • Tingkat aktivitas
        • Kondisi tubuh
    </string>
    <string name="materi_perhitungan">Cara Perhitungan</string>
    <string name="materi_perhitungan_desc">Kebutuhan air dihitung berdasarkan berat
        badan dan aktivitas, sedangkan kebutuhan kalori dihitung dari kebutuhan
        energi harian.
    </string>
    <string name="materi_tips">Tips Sehat</string>
    <string name="materi_tips_desc">
        • Minum setiap 2–3 jam
        • Jangan menunggu haus
        • Konsumsi makanan bergizi
        • Sesuaikan asupan dengan aktivitas
    </string>

